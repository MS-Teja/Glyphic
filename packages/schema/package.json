{
  "name": "@glyphicjs/schema",
  "version": "1.1.1",
  "license": "MIT",
  "description": "Zod schema for Glyphic diagram inputs — the typed, machine-first contract LLMs emit instead of fragile DSLs or raw SVG.",
  "keywords": [
    "diagrams",
    "zod",
    "json-schema",
    "llm",
    "ai-agents",
    "diagram-generator",
    "mermaid-alternative",
    "validation"
  ],
  "repository": { "type": "git", "url": "git+https://github.com/MS-Teja/Glyphic.git", "directory": "packages/schema" },
  "homepage": "https://github.com/MS-Teja/Glyphic#readme",
  "bugs": { "url": "https://github.com/MS-Teja/Glyphic/issues" },
  "funding": "https://github.com/sponsors/MS-Teja",
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
