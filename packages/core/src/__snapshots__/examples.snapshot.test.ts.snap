exports[`docs/examples SVG snapshots (refactor guard) > renders 15_coffee_shop_sequence.json to a stable SVG 1`] = `
"<svg xmlns="http://www.w3.org/2000/svg" width="2020" height="1260" viewBox="0 0 2020 1260" role="img">
<defs>

        <marker id="arrow-solid" viewBox="0 0 12 12" refX="10" refY="6" markerWidth="8" markerHeight="8" orient="auto">
