{
  "name": "@glyphicjs/core",
  "version": "1.2.5",
  "license": "FSL-1.1-ALv2",
  "description": "Layout and rendering engine for Glyphic — typed JSON in, deterministic SVG & PNG out, no headless browser. Built for LLMs and agents.",
  "keywords": [
    "diagrams",
    "diagram-generator",
    "svg",
    "png",
    "llm",
    "ai-agents",
    "mermaid-alternative",
    "text-to-diagram",
    "layout-engine",
    "elkjs"
  ],
  "repository": { "type": "git", "url": "git+https://github.com/MS-Teja/Glyphic.git", "directory": "packages/core" },
  "homepage": "https://github.com/MS-Teja/Glyphic#readme",
  "bugs": { "url": "https://github.com/MS-Teja/Glyphic/issues" },
  "funding": "https://github.com/sponsors/MS-Teja",
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public" },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@glyphicjs/schema": "workspace:^",
    "@resvg/resvg-js": "^2.6.2",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0",
    "elkjs": "^0.9.3"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
