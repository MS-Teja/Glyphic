{
  "name": "@glyphicjs/mcp-server",
  "version": "1.1.2",
  "license": "MIT",
  "description": "Model Context Protocol server for Glyphic — generate diagrams from structured JSON, no SVG, no headless browser. 18 diagram types for LLMs and agents.",
  "mcpName": "io.github.MS-Teja/glyphic",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "llm",
    "ai-agents",
    "diagrams",
    "diagram-generator",
    "text-to-diagram",
    "mermaid-alternative",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MS-Teja/Glyphic.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/MS-Teja/Glyphic#readme",
  "bugs": { "url": "https://github.com/MS-Teja/Glyphic/issues" },
  "funding": "https://github.com/sponsors/MS-Teja",
  "engines": { "node": ">=22" },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "bin": {
    "glyphic-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@glyphicjs/core": "workspace:^",
    "@glyphicjs/schema": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
