        { "name": "title", "type": "varchar(200)" },
        { "name": "body", "type": "text" }
      ]
    },
    {
      "id": "comments",
      "label": "comments",
      "color": "#10b981",
      "attributes": [
        { "name": "id", "type": "uuid", "key": "PK" },
