    { "id": "ci", "label": "CI checks", "shape": "rectangle" },
    { "id": "pass", "label": "Passing?", "shape": "diamond" },
    { "id": "review", "label": "Request review", "shape": "rectangle" },
    { "id": "fix", "label": "Push fixes", "shape": "rectangle" },
    { "id": "approve", "label": "Approved?", "shape": "diamond" },
    { "id": "merge", "label": "Merge", "shape": "rounded", "metadata": { "color": "#10b981" } }
