          <path d="M 0 7 L 8 1 L 16 7 L 8 13 z" fill="#fefce8" stroke="#a16207" stroke-width="2" />
        </marker>
        
        <marker id="arrow-crow-solid" viewBox="0 0 24 20" refX="20" refY="10" markerWidth="14" markerHeight="14" orient="auto">
          <path d="M 0 10 L 22 10 M 12 10 L 22 0 M 12 10 L 22 20" fill="none" stroke="#a16207" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </marker>
