{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": ["dist", "node_modules", ".turbo", "**/*.snap", "docs/examples", "internal"]
  },
  "formatter": {
    "enabled": false
  },
  "organizeImports": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noDebugger": "error",
        "noDuplicateObjectKeys": "error",
        "noDoubleEquals": "error"
      },
      "correctness": {
        "noUnreachable": "error",
        "noUnusedVariables": "off"
      }
    }
  }
}
