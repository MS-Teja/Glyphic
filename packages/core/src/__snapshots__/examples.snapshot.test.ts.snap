exports[`docs/examples SVG snapshots (refactor guard) > renders 18_mars_mission_gantt.json to a stable SVG 1`] = `
"<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1120" viewBox="0 0 1080 1120" role="img" aria-label="Mars Colony Alpha: Mission Timeline">
